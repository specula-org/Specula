#!/usr/bin/env bash
#
# specula — unified command-line entrypoint for the Specula pipeline.
# Thin shim → Python dispatcher (src/specula/cli.py); after `pip install -e .`
# the same dispatcher is on PATH as the `specula` console script. Every
# argument is forwarded verbatim and the exit code propagates via exec.
set -euo pipefail

# Resolve this script's real directory, following symlinks so it keeps working
# when symlinked onto PATH. Kept portable (no `readlink -f`, which is non-POSIX).
SOURCE="${BASH_SOURCE[0]}"
while [ -h "$SOURCE" ]; do
  src_dir="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  if [[ "$SOURCE" != /* ]]; then SOURCE="$src_dir/$SOURCE"; fi
done
SPECULA_ROOT="$(cd -P "$(dirname "$SOURCE")" && pwd)"

# Import the checkout as a real package without exporting PYTHONPATH. Isolated
# mode also keeps the analyzed repository out of sys.path, so a target json.py
# cannot shadow Python's standard library inside the dispatcher.
exec python3 -I -c \
  'import sys; sys.path.insert(0, sys.argv.pop(1)); from specula.cli import main; raise SystemExit(main())' \
  "$SPECULA_ROOT/src" "$@"
